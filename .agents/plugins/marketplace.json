{
  "name": "gpt-relay-host-bridge",
  "interface": {
    "displayName": "GPT & Gemini Relay"
  },
  "plugins": [
    {
      "name": "gpt-relay",
      "source": {
        "source": "local",
        "path": "./plugins/gpt-relay"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    },
    {
      "name": "gemini-relay",
      "source": {
        "source": "local",
        "path": "./plugins/gemini-relay"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    }
  ]
}
